# 🔐 Required: Security Tokens
# Generate with: openssl rand -base64 48
AGGREGATION_SERVICE_TOKEN=
SECRET_KEY=

# 🗄️ Required: Database
# Railway/Render provides this automatically
DATABASE_URL=postgresql://user:password@localhost:5432/walker_app

# 🌐 Required: CORS (Update with your actual frontend URL)
CORS_ORIGINS=https://your-app.vercel.app


